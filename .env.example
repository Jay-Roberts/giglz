# Spotify API credentials (from developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5001/callback

# Your Spotify user ID — only this user can import shows
# Find at: spotify.com/account or in your profile URL
HOST_USER_ID=your-spotify-user-id

# Flask session secret — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-insecure-change-me

# Optional: OpenRouter API key for URL import (LLM extraction)
OPENROUTER_API_KEY=your-openrouter-key

# Optional: Allow specific Spotify users to log in (host always allowed)
# ALLOWED_USER_IDS=friend1_spotify_id,friend2_spotify_id
